#!/usr/bin/env python3
"""
query-logs <type> [filter]

Reads the Unity AI Bridge structured log file and returns entries matching
the given type. The log is written by LogWriter.cs at Logs/unity-ai-bridge.log
under the Unity project root, and is cleared each time Play Mode starts.

Type argument is required — no raw dump is possible.
An optional substring filter narrows results further.

Types: Error  Warning  Log  Exception  Assert

Hard result cap: 100 entries. Any limit:N argument is silently ignored.

Examples:
  query-logs Error
  query-logs Warning "NullReference"
  query-logs Log "[UnityAIBridge]"
"""

import os
import re
import sys

RESULT_CAP = 100
VALID_TYPES = {"Error", "Warning", "Log", "Exception", "Assert"}

LOG_FILENAME = os.path.join("Logs", "unity-ai-bridge.log")

# Header pattern written by LogWriter: [HH:MM:SS.mmm] [Type] message
HEADER_RE = re.compile(r"^\[\d{2}:\d{2}:\d{2}\.\d{3}\] \[(\w+)\] ")


# ── Log file location ─────────────────────────────────────────────────────────

def find_log_path():
    """Walk up from the script location to find the Unity project root."""
    # Tools/ lives at the project root, so start one level up from this script
    candidate = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    for _ in range(6):
        log = os.path.join(candidate, LOG_FILENAME)
        if os.path.exists(log):
            return log
        # Also accept a root that has an Assets/ folder (project root)
        if os.path.isdir(os.path.join(candidate, "Assets")):
            return os.path.join(candidate, LOG_FILENAME)
        candidate = os.path.dirname(candidate)
    return None


# ── Log parsing ───────────────────────────────────────────────────────────────

def parse_entries(log_path):
    """
    Split the log into entries. Each entry starts with a [HH:MM:SS.mmm] [Type]
    header line and is terminated by a blank line.
    """
    entries = []
    current = []
    try:
        with open(log_path, "r", errors="replace") as f:
            for line in f:
                stripped = line.rstrip()
                if stripped == "":
                    if current:
                        entries.append("\n".join(current))
                        current = []
                else:
                    current.append(stripped)
    except OSError as e:
        print(f"Error reading log file: {e}", file=sys.stderr)
        sys.exit(1)

    if current:
        entries.append("\n".join(current))

    return entries


def classify(entry):
    m = HEADER_RE.match(entry)
    return m.group(1) if m else "Log"


# ── Main ──────────────────────────────────────────────────────────────────────

def main():
    raw_args = [a for a in sys.argv[1:] if not a.lower().startswith("limit:")]

    if not raw_args:
        print("Usage: query-logs <type> [filter]", file=sys.stderr)
        print(f"Types: {', '.join(sorted(VALID_TYPES))}", file=sys.stderr)
        sys.exit(1)

    log_type = raw_args[0]
    substring = raw_args[1] if len(raw_args) > 1 else None

    if log_type not in VALID_TYPES:
        print(f"Error: Unknown type '{log_type}'.", file=sys.stderr)
        print(f"Valid types: {', '.join(sorted(VALID_TYPES))}", file=sys.stderr)
        sys.exit(1)

    log_path = find_log_path()
    if log_path is None or not os.path.exists(log_path):
        print("Error: unity-ai-bridge.log not found.", file=sys.stderr)
        print("Open Unity with the AI Bridge package installed to generate the log.", file=sys.stderr)
        sys.exit(1)

    entries = parse_entries(log_path)

    results = []
    for entry in entries:
        if classify(entry) != log_type:
            continue
        if substring and substring.lower() not in entry.lower():
            continue
        results.append(entry)
        if len(results) >= RESULT_CAP:
            break

    if not results:
        print(f"No {log_type} entries found.", file=sys.stderr)
        return

    for i, entry in enumerate(results):
        if i > 0:
            print()
        print(entry)

    if len(results) == RESULT_CAP:
        print(f"\n# Capped at {RESULT_CAP} results", file=sys.stderr)


if __name__ == "__main__":
    main()
