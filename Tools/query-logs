#!/usr/bin/env python3
"""
query-logs <type> [filter]

Reads the Unity Editor log and returns entries matching the given type.
Type argument is required — no raw dump is possible.
An optional substring filter narrows results further.

Types: Error  Warning  Log  Exception  Assert

Hard result cap: 100 entries. Any limit:N argument is silently ignored.

Examples:
  query-logs Error
  query-logs Warning "NullReference"
  query-logs Log "[UnityAIBridge]"
  query-logs Error limit:10    # limit ignored — cap is always 100
"""

import os
import platform
import re
import sys

RESULT_CAP = 100
VALID_TYPES = {"Error", "Warning", "Log", "Exception", "Assert"}


# ── Log file location ─────────────────────────────────────────────────────────

def find_log_path():
    system = platform.system()
    if system == "Darwin":
        return os.path.expanduser("~/Library/Logs/Unity/Editor.log")
    if system == "Windows":
        local = os.environ.get("LOCALAPPDATA", "")
        return os.path.join(local, "Unity", "Editor", "Editor.log")
    # Linux
    return os.path.expanduser("~/.config/unity3d/Editor.log")


# ── Log parsing ───────────────────────────────────────────────────────────────

def parse_entries(log_path):
    """
    Split the log file into entries. Each entry is a block of lines terminated
    by a blank line. Entries without content are discarded.
    """
    entries = []
    current = []
    try:
        with open(log_path, "r", errors="replace") as f:
            for line in f:
                stripped = line.rstrip()
                if stripped == "":
                    if current:
                        entries.append("\n".join(current))
                        current = []
                else:
                    current.append(stripped)
    except OSError as e:
        print(f"Error reading log file: {e}", file=sys.stderr)
        sys.exit(1)

    if current:
        entries.append("\n".join(current))

    return entries


def classify(entry):
    """
    Classify a log entry as one of the five Unity log types.

    Priority order:
      1. Exception — first line matches ExceptionName: pattern
      2. Error     — stack trace contains Debug:LogError, or first line starts with "Error"
      3. Warning   — stack trace contains Debug:LogWarning, or first line starts with "Warning"
      4. Assert    — stack trace contains Debug:Assert
      5. Log       — everything else (including plain Debug:Log)
    """
    lines = entry.split("\n")
    first = lines[0]

    if re.match(r"\w+Exception:", first):
        return "Exception"

    # Stack-trace markers are the most reliable signal
    if "Debug:LogError" in entry or "UnityEngine.Debug:LogError" in entry:
        return "Error"
    if "Debug:LogWarning" in entry or "UnityEngine.Debug:LogWarning" in entry:
        return "Warning"
    if "Debug:Assert" in entry or "UnityEngine.Debug:Assert" in entry:
        return "Assert"

    # Heuristic: first-line prefix (catches editor-internal messages)
    first_lower = first.lower()
    if re.match(r"error[:\s]", first_lower):
        return "Error"
    if re.match(r"warning[:\s]", first_lower):
        return "Warning"

    return "Log"


# ── Main ──────────────────────────────────────────────────────────────────────

def main():
    # Strip any limit:N tokens — the cap is internal and cannot be overridden
    raw_args = [a for a in sys.argv[1:] if not a.lower().startswith("limit:")]

    if not raw_args:
        print("Usage: query-logs <type> [filter]", file=sys.stderr)
        print(f"Types: {', '.join(sorted(VALID_TYPES))}", file=sys.stderr)
        sys.exit(1)

    log_type = raw_args[0]
    substring = raw_args[1] if len(raw_args) > 1 else None

    if log_type not in VALID_TYPES:
        print(f"Error: Unknown type '{log_type}'.", file=sys.stderr)
        print(f"Valid types: {', '.join(sorted(VALID_TYPES))}", file=sys.stderr)
        sys.exit(1)

    log_path = find_log_path()
    if not os.path.exists(log_path):
        print(f"Error: Unity Editor.log not found at {log_path}.", file=sys.stderr)
        print("Open Unity at least once to generate the log file.", file=sys.stderr)
        sys.exit(1)

    entries = parse_entries(log_path)

    results = []
    for entry in entries:
        if classify(entry) != log_type:
            continue
        if substring and substring.lower() not in entry.lower():
            continue
        results.append(entry)
        if len(results) >= RESULT_CAP:
            break

    if not results:
        print(f"No {log_type} entries found.", file=sys.stderr)
        return

    for i, entry in enumerate(results):
        if i > 0:
            print()
        print(entry)

    if len(results) == RESULT_CAP:
        print(f"\n# Capped at {RESULT_CAP} results", file=sys.stderr)


if __name__ == "__main__":
    main()
