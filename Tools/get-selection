#!/usr/bin/env python3
"""
get-selection [scene-name]

Reads selection.json for the given scene and prints the UUID array.
If no scene name is given, searches Assets/SceneData/ for a single selection.json.

Fails with a clear error if selection.json is not found (Unity not initialized).

Examples:
    get-selection
    get-selection Level_A
"""

import json
import os
import sys

SEARCH_ROOT = "Assets/SceneData"


def find_scene_path(scene_name):
    for dirpath, _dirs, files in os.walk(SEARCH_ROOT):
        if "manifest.json" in files and os.path.basename(dirpath) == scene_name:
            return dirpath
    return None


def list_available_scenes():
    scenes = []
    for dirpath, _dirs, files in os.walk(SEARCH_ROOT):
        if "manifest.json" in files:
            scenes.append(os.path.relpath(dirpath, SEARCH_ROOT))
    return sorted(scenes)


def find_selection_files():
    results = []
    for dirpath, _, filenames in os.walk(SEARCH_ROOT):
        if "selection.json" in filenames:
            results.append(os.path.join(dirpath, "selection.json"))
    return results


def main():
    scene = sys.argv[1] if len(sys.argv) > 1 else None

    if scene:
        scene_path = find_scene_path(scene)
        if not scene_path:
            print(f"Error: Scene '{scene}' not found under {SEARCH_ROOT}", file=sys.stderr)
            available = list_available_scenes()
            if available:
                print("Available scenes (paths relative to Assets/SceneData):", file=sys.stderr)
                for s in available:
                    print(f"  {s}", file=sys.stderr)
            sys.exit(1)
        path = os.path.join(scene_path, "selection.json")
    else:
        found = find_selection_files()
        if len(found) == 0:
            print(
                "Error: No selection.json found. Is Unity open with a scene initialized?",
                file=sys.stderr,
            )
            sys.exit(1)
        elif len(found) > 1:
            print(
                "Error: Multiple scenes have selection.json. Specify a scene name:",
                file=sys.stderr,
            )
            for f in found:
                print(f"  {f}", file=sys.stderr)
            sys.exit(1)
        path = found[0]

    if not os.path.exists(path):
        print(
            f"Error: selection.json not found at {path}. Is Unity open with the scene initialized?",
            file=sys.stderr,
        )
        sys.exit(1)

    with open(path) as f:
        data = json.load(f)

    print(json.dumps(data, indent=2))


if __name__ == "__main__":
    main()
