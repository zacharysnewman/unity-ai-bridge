#!/usr/bin/env python3
"""
patch-entities <scene> "<filter>" "<patch>"
patch-entities <scene> --stdin "<patch>"
patch-entities <scene> --undo
patch-entities <scene> --history

Applies a patch expression to all entities matching a filter.
Writes are applied directly to entity JSON files — Unity hot-reloads instantly.
Every patch is recorded in patch-history.json (last 10 entries) for undo.

Patch operators: =  +=  -=  *=  /=  %=

Field paths (same as query-scene):
  transform.pos.x / .y / .z
  transform.rot.x / .y / .z
  transform.scl.x / .y / .z
  name, activeSelf, isStatic, tag, layer, prefabPath, parentUuid, siblingIndex
  Any field present in customData entries

--stdin reads UUIDs from stdin (one per line or JSON array) instead of running
a filter, making it composable with query-scene and get-visible-objects:

  query-scene Level_A "prefab contains Cube" | patch-entities --stdin Level_A "transform.pos.y += 2"
  get-visible-objects Level_A | patch-entities --stdin Level_A "transform.pos.y += 2"

--undo reverts the most recent patch recorded in patch-history.json.

--history prints a one-line summary of each recorded patch (timestamp, description, count).

Examples:
  patch-entities Level_A "prefab contains Cube" "transform.pos.y += 2"
  patch-entities Level_A "component == Enemy" "transform.rot.y = 0"
  patch-entities Level_A "name contains Wall" "transform.scl.x *= 2"
  patch-entities Level_A "transform.pos.y < 0" "transform.pos.y = 0"
  patch-entities Level_A "prefab contains Coin" "transform.pos.y %= 3"
  patch-entities Level_A --undo
  patch-entities Level_A --history
"""

import json
import os
import re
import sys
from datetime import datetime, timezone

SEARCH_ROOT = "Assets/SceneData"
AXIS_INDEX = {"x": 0, "y": 1, "z": 2}
HISTORY_FILE = "patch-history.json"
HISTORY_LIMIT = 10


# ── Scene discovery ────────────────────────────────────────────────────────────

def find_scene_path(scene_name):
    for dirpath, _dirs, files in os.walk(SEARCH_ROOT):
        if "manifest.json" in files and os.path.basename(dirpath) == scene_name:
            return dirpath
    return None


def list_available_scenes():
    scenes = []
    for dirpath, _dirs, files in os.walk(SEARCH_ROOT):
        if "manifest.json" in files:
            scenes.append(os.path.relpath(dirpath, SEARCH_ROOT))
    return sorted(scenes)


# ── Filter (from query-scene) ──────────────────────────────────────────────────

TOKEN_RE = re.compile(r'\bAND\b|\bOR\b|\bcontains\b|==|!=|>=|<=|>|<|%|"[^"]*"|\'[^\']*\'|\S+')
OPERATORS = {"==", "!=", ">=", "<=", ">", "<", "contains"}


def tokenize(expr):
    return TOKEN_RE.findall(expr)


class Cmp:
    def __init__(self, field, op, value):
        self.field = field; self.op = op; self.value = value.strip('"\'')

class ModCmp:
    def __init__(self, field, modulus, op, value):
        self.field = field; self.modulus = modulus.strip('"\'')
        self.op = op; self.value = value.strip('"\'')

class And:
    def __init__(self, left, right):
        self.left = left; self.right = right

class Or:
    def __init__(self, left, right):
        self.left = left; self.right = right


def parse_filter(expr):
    tokens = tokenize(expr)
    pos = [0]

    def peek(): return tokens[pos[0]] if pos[0] < len(tokens) else None
    def consume():
        t = tokens[pos[0]]; pos[0] += 1; return t

    def parse_cmp():
        field = consume(); op = consume()
        if op == "%":
            modulus = consume(); cmp_op = consume()
            if cmp_op not in OPERATORS: raise ValueError(f"Unknown operator: {cmp_op!r}")
            return ModCmp(field, modulus, cmp_op, consume())
        if op not in OPERATORS: raise ValueError(f"Unknown operator: {op!r}")
        return Cmp(field, op, consume())

    def parse_and():
        left = parse_cmp()
        while peek() == "AND": consume(); left = And(left, parse_cmp())
        return left

    def parse_or():
        left = parse_and()
        while peek() == "OR": consume(); left = Or(left, parse_and())
        return left

    return parse_or()


def cmp_values(actual, op, expected):
    if actual is None:
        null_values = {"null", "none", ""}
        if op == "==": return str(expected).lower() in null_values
        if op == "!=": return str(expected).lower() not in null_values
        return False
    try:
        a, b = float(actual), float(expected)
        return {"==": a == b, "!=": a != b, ">=": a >= b,
                "<=": a <= b, ">": a > b, "<": a < b}[op]
    except (ValueError, TypeError, KeyError):
        pass
    a_s, b_s = str(actual).lower(), str(expected).lower()
    if op == "contains": return b_s in a_s
    if op == "==": return a_s == b_s
    if op == "!=": return a_s != b_s
    return False


def get_entity_field(entity, field):
    parts = field.lower().split(".")
    if len(parts) == 3 and parts[0] == "transform" and parts[2] in AXIS_INDEX:
        arr = entity.get("transform", {}).get(parts[1], [])
        idx = AXIS_INDEX[parts[2]]
        return arr[idx] if idx < len(arr) else None
    f = field.lower()
    top_map = {"name": "name", "prefab": "prefabPath", "prefabpath": "prefabPath",
               "parent": "parentUuid", "parentuuid": "parentUuid", "siblingindex": "siblingIndex",
               "tag": "tag", "layer": "layer", "isstatic": "isStatic", "activeself": "activeSelf"}
    if f in top_map: return entity.get(top_map[f])
    for comp in entity.get("builtInComponents", []) + entity.get("customData", []):
        if field in comp: return comp[field]
    return None


def eval_filter(node, entity):
    if isinstance(node, And): return eval_filter(node.left, entity) and eval_filter(node.right, entity)
    if isinstance(node, Or): return eval_filter(node.left, entity) or eval_filter(node.right, entity)
    if isinstance(node, Cmp):
        if node.field.lower() == "component":
            for comp in entity.get("builtInComponents", []) + entity.get("customData", []):
                t = comp.get("type", ""); short = t.split(".")[-1]
                if cmp_values(t, node.op, node.value) or cmp_values(short, node.op, node.value):
                    return True
            return False
        return cmp_values(get_entity_field(entity, node.field), node.op, node.value)
    if isinstance(node, ModCmp):
        actual = get_entity_field(entity, node.field)
        if actual is None: return False
        try:
            return cmp_values(float(actual) % float(node.modulus), node.op, node.value)
        except (ValueError, TypeError): return False
    return False


# ── Patch expression ───────────────────────────────────────────────────────────

PATCH_RE = re.compile(r'^(\S+)\s*(=|\+=|-=|\*=|/=|%=)\s*(.+)$')
PATCH_OPS = {"=", "+=", "-=", "*=", "/=", "%="}


def parse_value(raw):
    raw = raw.strip()
    if raw.lower() == "true": return True
    if raw.lower() == "false": return False
    if raw.lower() == "null": return None
    if (raw.startswith('"') and raw.endswith('"')) or \
       (raw.startswith("'") and raw.endswith("'")):
        return raw[1:-1]
    try: return int(raw)
    except ValueError: pass
    try: return float(raw)
    except ValueError: pass
    return raw


def parse_patch(expr):
    m = PATCH_RE.match(expr.strip())
    if not m:
        raise ValueError(f"Invalid patch expression: {expr!r}\nExpected: <field> <op> <value>")
    field, op, raw = m.group(1), m.group(2), m.group(3)
    return field, op, parse_value(raw)


def apply_op(current, op, value):
    if op == "=":
        return value
    try:
        c, v = float(current), float(value)
    except (TypeError, ValueError):
        raise ValueError(f"Operator {op!r} requires numeric values, got {current!r}")
    if op == "/=" and v == 0:
        raise ValueError("Division by zero")
    result = {"+=": c + v, "-=": c - v, "*=": c * v, "/=": c / v, "%=": c % v}[op]
    if isinstance(current, int) and isinstance(value, int) and result == int(result):
        return int(result)
    return result


def set_entity_field(entity, field, op, value):
    """Apply op+value to field in entity. Returns True if field was found and set."""
    parts = field.lower().split(".")
    if len(parts) == 3 and parts[0] == "transform" and parts[2] in AXIS_INDEX:
        t = entity.setdefault("transform", {})
        arr = t.setdefault(parts[1], [0.0, 0.0, 0.0])
        while len(arr) < 3: arr.append(0.0)
        idx = AXIS_INDEX[parts[2]]
        arr[idx] = apply_op(arr[idx], op, value)
        return True

    f = field.lower()
    top_map = {"name": "name", "prefab": "prefabPath", "prefabpath": "prefabPath",
               "parent": "parentUuid", "parentuuid": "parentUuid", "siblingindex": "siblingIndex",
               "tag": "tag", "layer": "layer", "isstatic": "isStatic", "activeself": "activeSelf"}
    if f in top_map:
        key = top_map[f]
        entity[key] = apply_op(entity.get(key), op, value)
        return True

    for comp in entity.get("customData", []):
        if field in comp:
            comp[field] = apply_op(comp[field], op, value)
            return True

    if op == "=":
        entity[field] = value
        return True

    return False


# ── Patch history ──────────────────────────────────────────────────────────────

def load_history(scene_path):
    path = os.path.join(scene_path, HISTORY_FILE)
    if not os.path.exists(path):
        return []
    try:
        with open(path) as f:
            return json.load(f)
    except (json.JSONDecodeError, OSError):
        return []


def save_history(scene_path, history):
    path = os.path.join(scene_path, HISTORY_FILE)
    with open(path, "w") as f:
        json.dump(history, f, indent=2)


def push_history(scene_path, entry_type, description, changes):
    history = load_history(scene_path)
    entry = {
        "timestamp": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        "type": entry_type,
        "description": description,
        "count": len(changes),
        "changes": changes,
    }
    history.insert(0, entry)
    save_history(scene_path, history[:HISTORY_LIMIT])


# ── Stdin UUID reading ─────────────────────────────────────────────────────────

def read_uuids_from_stdin():
    raw = sys.stdin.read().strip()
    if not raw: return []
    if raw.startswith("["):
        return json.loads(raw)
    return [line.strip() for line in raw.splitlines() if line.strip()]


# ── Subcommands ────────────────────────────────────────────────────────────────

def cmd_history(scene_path):
    history = load_history(scene_path)
    if not history:
        print("No patch history.")
        return
    for i, entry in enumerate(history):
        print(f"[{i}] {entry['timestamp']}  {entry['description']}  ({entry['count']} object(s))")


def cmd_undo(scene_path, entities_dir):
    history = load_history(scene_path)
    if not history:
        print("Nothing to undo.")
        return

    entry = history[0]
    entry_type = entry.get("type", "patch")
    reverted, errors = 0, 0

    if entry_type == "patch":
        for change in entry.get("changes", []):
            uuid = change["uuid"]
            field = change["field"]
            before = change["before"]
            entity_path = os.path.join(entities_dir, uuid + ".json")
            if not os.path.exists(entity_path):
                print(f"Warning: {uuid} not found, skipping.", file=sys.stderr)
                errors += 1
                continue
            try:
                with open(entity_path) as f:
                    entity = json.load(f)
                set_entity_field(entity, field, "=", before)
                with open(entity_path, "w") as f:
                    json.dump(entity, f, indent=2)
                reverted += 1
            except Exception as e:
                print(f"Warning: {uuid}: {e}", file=sys.stderr)
                errors += 1

    elif entry_type == "delete":
        for change in entry.get("changes", []):
            uuid = change["uuid"]
            entity = change.get("entity", {})
            entity_path = os.path.join(entities_dir, uuid + ".json")
            try:
                with open(entity_path, "w") as f:
                    json.dump(entity, f, indent=2)
                reverted += 1
            except Exception as e:
                print(f"Warning: could not restore {uuid}: {e}", file=sys.stderr)
                errors += 1

    elif entry_type == "create":
        for change in entry.get("changes", []):
            uuid = change["uuid"]
            entity_path = os.path.join(entities_dir, uuid + ".json")
            if not os.path.exists(entity_path):
                print(f"Warning: {uuid} not found, skipping.", file=sys.stderr)
                errors += 1
                continue
            try:
                os.remove(entity_path)
                reverted += 1
            except Exception as e:
                print(f"Warning: could not remove {uuid}: {e}", file=sys.stderr)
                errors += 1

    history.pop(0)
    save_history(scene_path, history)

    parts = [f"Reverted '{entry['description']}' on {reverted} object(s)."]
    if errors: parts.append(f"{errors} error(s).")
    print(" ".join(parts))


# ── Main ───────────────────────────────────────────────────────────────────────

def main():
    args = sys.argv[1:]
    use_stdin = "--stdin" in args
    do_undo = "--undo" in args
    do_history = "--history" in args
    args = [a for a in args if a not in ("--stdin", "--undo", "--history")]

    if not args:
        print("Usage: patch-entities <scene> \"<filter>\" \"<patch>\"", file=sys.stderr)
        sys.exit(1)

    scene_name = args[0]
    args = args[1:]

    scene_path = find_scene_path(scene_name)
    if not scene_path:
        print(f"Error: Scene '{scene_name}' not found under {SEARCH_ROOT}", file=sys.stderr)
        available = list_available_scenes()
        if available:
            print("Available scenes (paths relative to Assets/SceneData):", file=sys.stderr)
            for s in available: print(f"  {s}", file=sys.stderr)
        sys.exit(1)

    entities_dir = os.path.join(scene_path, "Entities")
    if not os.path.isdir(entities_dir):
        print(f"Error: Entities directory not found at {entities_dir}", file=sys.stderr)
        sys.exit(1)

    if do_history:
        cmd_history(scene_path)
        return

    if do_undo:
        cmd_undo(scene_path, entities_dir)
        return

    # Normal patch mode
    if use_stdin:
        if len(args) < 1:
            print("Usage: patch-entities <scene> --stdin \"<patch>\"", file=sys.stderr)
            sys.exit(1)
        patch_expr = args[0]
        filter_ast = None
    else:
        if len(args) < 2:
            print("Usage: patch-entities <scene> \"<filter>\" \"<patch>\"", file=sys.stderr)
            sys.exit(1)
        filter_expr, patch_expr = args[0], args[1]
        try:
            filter_ast = parse_filter(filter_expr)
        except Exception as e:
            print(f"Error parsing filter: {e}", file=sys.stderr)
            sys.exit(1)

    try:
        patch_field, patch_op, patch_value = parse_patch(patch_expr)
    except ValueError as e:
        print(f"Error parsing patch: {e}", file=sys.stderr)
        sys.exit(1)

    if use_stdin:
        uuids = read_uuids_from_stdin()
    else:
        uuids = [os.path.splitext(f)[0] for f in os.listdir(entities_dir) if f.endswith(".json")]

    patched, skipped, errors = 0, 0, 0
    changes = []

    for uuid in uuids:
        entity_path = os.path.join(entities_dir, uuid + ".json")
        if not os.path.exists(entity_path):
            skipped += 1
            continue

        try:
            with open(entity_path) as f:
                entity = json.load(f)
        except Exception as e:
            print(f"Warning: could not read {uuid}: {e}", file=sys.stderr)
            errors += 1
            continue

        if filter_ast and not eval_filter(filter_ast, entity):
            skipped += 1
            continue

        before_value = get_entity_field(entity, patch_field)

        try:
            found = set_entity_field(entity, patch_field, patch_op, patch_value)
        except ValueError as e:
            print(f"Warning: {uuid} ({entity.get('name', '?')}): {e}", file=sys.stderr)
            errors += 1
            continue

        if not found:
            print(f"Warning: {uuid} ({entity.get('name', '?')}): field '{patch_field}' not found", file=sys.stderr)
            errors += 1
            continue

        try:
            with open(entity_path, "w") as f:
                json.dump(entity, f, indent=2)
            patched += 1
            changes.append({"uuid": uuid, "field": patch_field, "before": before_value})
        except Exception as e:
            print(f"Warning: could not write {uuid}: {e}", file=sys.stderr)
            errors += 1

    if changes:
        try:
            push_history(scene_path, "patch", patch_expr.strip(), changes)
        except Exception as e:
            print(f"Warning: could not write patch history: {e}", file=sys.stderr)

    parts = [f"Patched {patched} entity/entities."]
    if errors: parts.append(f"{errors} error(s).")
    print(" ".join(parts))


if __name__ == "__main__":
    main()
