#!/usr/bin/env python3
"""
select-objects [scene-name] <uuid>...

Writes a UUID array to selection.json. Unity picks up the change within ~300ms.
Pass no UUIDs to clear the selection.

If no scene name is given, searches Assets/SceneData/ for a single selection.json.
Scene name is detected automatically: if the first argument looks like a UUID
(contains hyphens), all arguments are treated as UUIDs.

Fails with a clear error if selection.json is not found (Unity not initialized).

Examples:
    select-objects 0eb2de67-e29b-41d4-a716-446655440000
    select-objects Level_A 0eb2de67-e29b-41d4-a716-446655440000 4b0f504e-1234-5678-abcd-000000000001
    select-objects          # clears selection (searches for single scene)
    select-objects Level_A  # clears selection for Level_A
"""

import json
import os
import sys

SEARCH_ROOT = "Assets/SceneData"

UUID_CHARS = set("0123456789abcdefABCDEF-")


def looks_like_uuid(s):
    return "-" in s and all(c in UUID_CHARS for c in s)


def find_scene_path(scene_name):
    for dirpath, _dirs, files in os.walk(SEARCH_ROOT):
        if "manifest.json" in files and os.path.basename(dirpath) == scene_name:
            return dirpath
    return None


def list_available_scenes():
    scenes = []
    for dirpath, _dirs, files in os.walk(SEARCH_ROOT):
        if "manifest.json" in files:
            scenes.append(os.path.relpath(dirpath, SEARCH_ROOT))
    return sorted(scenes)


def find_selection_files():
    results = []
    for dirpath, _, filenames in os.walk(SEARCH_ROOT):
        if "selection.json" in filenames:
            results.append(os.path.join(dirpath, "selection.json"))
    return results


def main():
    args = sys.argv[1:]

    # Determine if the first arg is a scene name or a UUID
    scene = None
    uuids = []

    if args and not looks_like_uuid(args[0]):
        scene = args[0]
        uuids = args[1:]
    else:
        uuids = args

    if scene:
        scene_path = find_scene_path(scene)
        if not scene_path:
            print(f"Error: Scene '{scene}' not found under {SEARCH_ROOT}", file=sys.stderr)
            available = list_available_scenes()
            if available:
                print("Available scenes (paths relative to Assets/SceneData):", file=sys.stderr)
                for s in available:
                    print(f"  {s}", file=sys.stderr)
            sys.exit(1)
        path = os.path.join(scene_path, "selection.json")
    else:
        found = find_selection_files()
        if len(found) == 0:
            print(
                "Error: No selection.json found. Is Unity open with a scene initialized?",
                file=sys.stderr,
            )
            sys.exit(1)
        elif len(found) > 1:
            print(
                "Error: Multiple scenes have selection.json. Specify a scene name:",
                file=sys.stderr,
            )
            for f in found:
                print(f"  {f}", file=sys.stderr)
            sys.exit(1)
        path = found[0]

    if not os.path.exists(path):
        print(
            f"Error: selection.json not found at {path}. Is Unity open with the scene initialized?",
            file=sys.stderr,
        )
        sys.exit(1)

    with open(path, "w") as f:
        json.dump(uuids, f, indent=2)

    if uuids:
        print(f"Selected {len(uuids)} object(s). Unity will update within ~300ms.")
    else:
        print("Selection cleared. Unity will update within ~300ms.")


if __name__ == "__main__":
    main()
