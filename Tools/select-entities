#!/usr/bin/env python3
"""
select-entities [scene-name] <uuid>...
select-entities [scene-name] --stdin

Writes UUIDs into the selection field of editor-state.json, preserving the other
editor state fields (scenePath, sceneCamera, visibleObjects). Unity picks up
the change instantly.

Pass no UUIDs to clear the selection.

--stdin reads UUIDs from stdin. Accepts a JSON array or one UUID per line,
making it composable with get-visible-objects and query-scene:

    Tools/get-visible-objects | Tools/select-entities --stdin
    Tools/query-scene Level_A "component == Enemy" | Tools/select-entities --stdin

If no scene name is given, searches Assets/SceneData/ for a single editor-state.json.
Scene name is detected automatically: if the first argument looks like a UUID
(contains hyphens), all arguments are treated as UUIDs.

Examples:
    select-entities 0eb2de67-e29b-41d4-a716-446655440000
    select-entities Level_A 0eb2de67-e29b-41d4-a716-446655440000 4b0f504e-1234-5678-abcd-000000000001
    select-entities          # clears selection (searches for single scene)
    select-entities Level_A  # clears selection for Level_A
    select-entities --stdin  # read UUIDs from stdin
"""

import json
import os
import sys

STATE_FILE = "editor-state.json"
SEARCH_ROOT = "Assets/SceneData"

UUID_CHARS = set("0123456789abcdefABCDEF-")


def looks_like_uuid(s):
    return "-" in s and all(c in UUID_CHARS for c in s)


def find_scene_path(scene_name):
    for dirpath, _dirs, files in os.walk(SEARCH_ROOT):
        if "manifest.json" in files and os.path.basename(dirpath) == scene_name:
            return dirpath
    return None


def list_available_scenes():
    scenes = []
    for dirpath, _dirs, files in os.walk(SEARCH_ROOT):
        if "manifest.json" in files:
            scenes.append(os.path.relpath(dirpath, SEARCH_ROOT))
    return sorted(scenes)


def find_state_files():
    results = []
    for dirpath, _, filenames in os.walk(SEARCH_ROOT):
        if STATE_FILE in filenames:
            results.append(os.path.join(dirpath, STATE_FILE))
    return results


def resolve_path(scene):
    if scene:
        scene_path = find_scene_path(scene)
        if not scene_path:
            print(f"Error: Scene '{scene}' not found under {SEARCH_ROOT}", file=sys.stderr)
            available = list_available_scenes()
            if available:
                print("Available scenes (paths relative to Assets/SceneData):", file=sys.stderr)
                for s in available:
                    print(f"  {s}", file=sys.stderr)
            sys.exit(1)
        return os.path.join(scene_path, STATE_FILE)
    else:
        found = find_state_files()
        if len(found) == 0:
            print(f"Error: No {STATE_FILE} found. Is Unity open with a scene initialized?", file=sys.stderr)
            sys.exit(1)
        elif len(found) > 1:
            print(f"Error: Multiple scenes found. Specify a scene name:", file=sys.stderr)
            for f in found:
                print(f"  {f}", file=sys.stderr)
            sys.exit(1)
        return found[0]


def read_uuids_from_stdin():
    raw = sys.stdin.read().strip()
    if not raw:
        return []
    # JSON array
    if raw.startswith("["):
        return json.loads(raw)
    # One UUID per line (query-scene format)
    return [line.strip() for line in raw.splitlines() if line.strip()]


def main():
    args = sys.argv[1:]

    scene = None
    uuids = []

    # Extract --stdin flag (may appear anywhere before or after scene name)
    use_stdin = "--stdin" in args
    args = [a for a in args if a != "--stdin"]

    if args and not looks_like_uuid(args[0]):
        scene = args[0]
        args = args[1:]

    if use_stdin:
        uuids = read_uuids_from_stdin()
    else:
        uuids = args

    path = resolve_path(scene)

    if not os.path.exists(path):
        print(f"Error: {STATE_FILE} not found at {path}. Is Unity open with the scene initialized?", file=sys.stderr)
        sys.exit(1)

    try:
        with open(path) as f:
            existing = json.load(f)
        if isinstance(existing, list):
            state = {"selection": existing, "scenePath": None, "sceneCamera": None, "visibleObjects": []}
        else:
            state = existing
    except (json.JSONDecodeError, OSError):
        state = {"selection": [], "scenePath": None, "sceneCamera": None, "visibleObjects": []}

    state["selection"] = uuids

    with open(path, "w") as f:
        json.dump(state, f, indent=2)

    if uuids:
        print(f"Selected {len(uuids)} entity/entities.")
    else:
        print("Selection cleared.")


if __name__ == "__main__":
    main()
